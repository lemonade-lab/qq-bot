# ============================================
# 服务器基础配置
# ============================================
# 服务监听端口（格式：:端口号，如 :8080）
PORT=:8080

# Gin 框架运行模式
# 可选值：debug（开发模式，详细日志）、release（生产模式，性能优化）
GIN_MODE=release

# ============================================
# CORS 跨域配置
# ============================================
# 允许的前端域名（多个用逗号分隔）
# 生产环境：必须配置实际的前端域名，如 https://bubble.alemonjs.com,https://bubble-base.alemonjs.com
ALLOWED_ORIGINS=*

# ============================================
# 数据库配置
# ============================================
# 数据库驱动类型
# 可选值：sqlite（SQLite 数据库）、mysql（MySQL 数据库）
DB_DRIVER=mysql

# 数据库连接字符串（DSN）
# SQLite 示例：file:bubble.db?cache=shared&_foreign_keys=1
# MySQL 示例：root:password@tcp(localhost:3306)/bubble?charset=utf8mb4&parseTime=True&loc=Local
# 注意：
#   - MySQL 字符集必须为 utf8mb4
#   - MySQL 排序规则建议使用 utf8mb4_general_ci
#   - 如果使用 Docker，MySQL 主机地址应为 mysql-bubble:3306（容器内）或 host.docker.internal:3006（主机）
DATABASE_DSN=root:Mm002580!@tcp(localhost:3306)/bubble?charset=utf8mb4&parseTime=True&loc=Local

# ============================================
# 认证和安全配置
# ============================================
# JWT 密钥（用于签名和验证 Token）
# 生产环境必须使用强随机密钥！如果未设置，系统会自动生成（不推荐）
# 生成方式：openssl rand -base64 32
JWT_SECRET=

# JWT Access Token 有效期（分钟）
# 建议值：5-15 分钟（短有效期可减少撤销延迟窗口）
JWT_ACCESS_MINUTES=5

# 会话 Cookie 名称
SESSION_COOKIE_NAME=bubble_session

# 是否允许匿名登录（开发测试用）
# 可选值：true、false
# 生产环境建议设置为 false
ALLOW_ANON_LOGIN=false

# 是否要求邮箱验证后才能登录
# 可选值：true、false
# 生产环境建议设置为 true
REQUIRE_EMAIL_VERIFIED=false

# ============================================
# Redis 配置（用于会话存储）
# ============================================
# Redis 服务器地址（格式：host:port）
# 如果使用 Docker，地址应为 redis-bubble:6379（容器内）或 localhost:6379（主机）
REDIS_ADDR=localhost:6379

# Redis 密码（如果 Redis 设置了密码）
REDIS_PASSWORD=

# Redis 数据库编号（0-15，默认 0）
REDIS_DB=0

# ============================================
# 邮件服务配置（腾讯云 SES）
# ============================================
# 是否启用邮件功能
# 可选值：true、false
EMAIL_ENABLED=true

# 腾讯云 SecretId（访问密钥ID）
# 获取方式：https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=your-secret-id

# 腾讯云 SecretKey（访问密钥密钥）
# 注意：请妥善保管，不要泄露
TENCENT_SECRET_KEY=your-secret-key

# 腾讯云 SES 服务地域
# 可选值：ap-guangzhou（广州）、ap-shanghai（上海）、ap-beijing（北京）等
# 完整列表：https://cloud.tencent.com/document/product/1288/51986
TENCENT_SES_REGION=ap-guangzhou

# 邮件模板ID
# 需要在腾讯云 SES 控制台创建邮件模板并获取模板ID
# 模板变量：{{account}}（账户名）、{{code}}（验证码）、{{time}}（有效期）
TENCENT_TEMPLATE_ID=39829

# 发件人邮箱地址
# 必须是在腾讯云 SES 中验证过的发信地址
EMAIL_FROM=app@e.alemonjs.com

# 发件人显示名称
EMAIL_FROM_NAME=Bubble

# ============================================
# 前端配置（用于邮件中的链接）
# ============================================
# 前端应用的 URL（用于邮件中的验证链接、重置密码链接等）
# 开发环境：http://localhost:5173
# 生产环境：https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ============================================
# MinIO 对象存储配置（用于文件存储）
# ============================================
# MinIO 服务地址（格式：host:port）
# 如果使用 Docker Compose，地址应为 minio-bubble:9000（容器内）
# 开发环境：localhost:19000
# 生产环境：请配置实际的 MinIO 服务器地址
MINIO_ENDPOINT=localhost:19000

# MinIO 访问密钥 ID
# 默认值：lemonade（开发环境）
# 生产环境必须修改为强密码！
MINIO_ACCESS_KEY_ID=lemonade

# MinIO 访问密钥（Secret Access Key）
# 默认值：lemonade（开发环境）
# 生产环境必须修改为强密码！
MINIO_SECRET_ACCESS_KEY=lemonade

# 是否使用 SSL/TLS 连接 MinIO
# 可选值：true、false
# 开发环境通常为 false，生产环境建议为 true
MINIO_USE_SSL=false

# MinIO 存储桶名称（Bucket）
# 用于存储用户头像、附件等文件
# 默认值：bubble
# 如果桶不存在，系统会自动创建
MINIO_BUCKET=bubble

# MinIO 存储桶列表（多个存储桶用逗号分隔）
# 默认值：bubble,backups,avatars,covers,emojis,temp,guild-chat-files,private-chat-files
# 如果未设置，将使用上述默认值
# 应用启动时会自动创建这些存储桶
MINIO_BUCKETS=bubble,backups,avatars,covers,emojis,temp,guild-chat-files,private-chat-files

# LiveKit 配置（用于音视频频道）
# LiveKit 服务器 WebSocket URL
# 本地开发：ws://localhost:7880
# Docker 环境：ws://host.docker.internal:7880
LIVEKIT_URL=ws://localhost:7880

# LiveKit API Key（从 docker-livekit.yaml 中获取）
LIVEKIT_API_KEY=APIm7qF8xK3pN9dL

# LiveKit API Secret（从 docker-livekit.yaml 中获取）
LIVEKIT_API_SECRET=secretW5nR2jH8tY6vX4cB9mP3qL7sF1kD

# ============================================
# FFmpeg 音频转换服务配置
# ============================================
# FFmpeg 服务地址（格式：http://host:port）
# 这是一个独立的 FFmpeg 转换服务，用于将音频文件转换为多平台兼容格式
# 开发环境：http://localhost:19080
# 生产环境：请配置实际的 FFmpeg 服务器地址
# 注意：如果不配置此项，音频转换功能将被禁用
FFMPEG_URL=http://localhost:19080

# ============================================
# 日志配置
# ============================================
# Logging Configuration
# 日志级别: debug, info, warn, error, fatal, panic
# 开发环境建议: debug 或 info
# 生产环境建议: info 或 warn
LOG_LEVEL=info

# 使用 JSON 格式输出日志（推荐用于生产环境）
# 开发环境: false（可读性更好的文本格式）
# 生产环境: true（便于日志收集和分析）
LOG_JSON=false

# 启用 Loki 日志收集
# 开发环境: false（可选，如果需要测试日志收集可设为 true）
# 生产环境: true（建议启用以便集中日志管理）
LOG_ENABLE_LOKI=false

# Loki 服务器地址
# 开发环境: http://localhost:13100/loki/api/v1/push（如果启用 docker-compose-logs.yaml）
# 生产环境: 配置实际的 Loki 服务器地址
LOKI_URL=http://localhost:13100/loki/api/v1/push

# 应用名称（用于 Loki 标签）
APP_NAME=bubble

# 环境（development, staging, production）
# 此配置会影响日志级别和格式的默认行为：
# - development: 启用详细调试信息，显示调用栈
# - production: 优化性能，限制最低日志级别为 info
ENVIRONMENT=development

# ===== 阿里云号码认证服务（短信验证码） =====
SMS_ENABLED=true
ALIYUN_ACCESS_KEY_ID=你的AccessKeyID
ALIYUN_ACCESS_SECRET=你的AccessKeySecret